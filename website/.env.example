# BetterAuth Configuration
BETTER_AUTH_SECRET="generate-a-random-secret-here"
BETTER_AUTH_URL="https://your-domain.com"

# Microsoft Entra ID (used by BetterAuth)
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""

# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# SSH
SSH_PRIVATE_KEY=""

NODE_TLS_REJECT_UNAUTHORIZED="0"

# Proxmox
PVE_HOST=""
PVE_PORT="443"
PVE_USER=""
PVE_NODE=""
NEXT_PUBLIC_PVE_HOST=""
NEXT_PUBLIC_PVE_PORT="443"
NEXT_PUBLIC_PVE_NODE=""
PVE_TOKEN_ID=""
PVE_TOKEN_SECRET=""
PVE_PASSWORD=""
PVE_CREATE_USER_PASSWORD=""

# Livestream
LIVESTREAM_URL=""
LIVESTREAM_SNAPSHOT_URL=""

# Email (SMTP)
# For Gmail: enable 2FA, generate an app password at
# myaccount.google.com → Security → App passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Jericho <you@gmail.com>"
