generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String         @id @default(cuid())
  name            String
  email           String         @unique
  emailVerified   Boolean        @default(false)
  image           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  proxmoxId       String?        @unique
  displayUsername String?
  username        String?        @unique
  banExpires      DateTime?
  banReason       String?
  banned          Boolean?       @default(false)
  role            String?
  userRoles       UserRole[]
  accounts        Account[]
  sessions        Session[]
  userAnswers     UserAnswer[]
  userHints       UserHint[]
  userScenarios   UserScenario[]
  vms             VM[]

  @@map("user")
}

model UserRole {
  id     String @id @default(cuid())
  role   Role
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VM {
  id            String         @id @default(cuid())
  proxmoxId     Int
  powerOffAt    DateTime?
  deleteAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  userId        String
  name          String?
  userScenarios UserScenario[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vm")
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model ScenarioLivestream {
  id         String   @id @default(cuid())
  scenarioId String
  label      String
  streamKey  String
  order      Int      @default(0)
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("scenario_livestream")
}

model LivestreamPageConfig {
  id        String                @id @default(cuid())
  layout    Int                   @default(1)
  updatedAt DateTime              @updatedAt
  streams   LivestreamPageStream[]

  @@map("livestream_page_config")
}

model LivestreamPageStream {
  id        String               @id @default(cuid())
  position  Int
  streamKey String
  label     String
  configId  String
  config    LivestreamPageConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("livestream_page_stream")
}

model Scenario {
  id                 String               @id @default(cuid())
  name               String
  description        String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  topologyURL        String?
  slug               String               @unique
  teaserText         String?
  teaserImageURL     String?
  learningObjectives String?
  topology           Json?
  questions          Question[]
  livestreams        ScenarioLivestream[]
  sections           Section[]
  userScenarios      UserScenario[]

  @@map("scenario")
}

model Section {
  id         String     @id @default(cuid())
  title      String
  order      Int
  scenarioId String
  questions  Question[]
  scenario   Scenario   @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("section")
}

model UserScenario {
  id          String    @id @default(cuid())
  userId      String
  scenarioId  String
  vmId        String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  hintsUsed   Int       @default(0)
  scenario    Scenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vm          VM?       @relation(fields: [vmId], references: [id])

  @@unique([userId, scenarioId])
  @@map("user_scenario")
}

model Question {
  id              String       @id @default(cuid())
  title           String
  placeholder     String
  validationRegex String?
  answer          String
  pointValue      Int          @default(10)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  scenarioId      String
  options         String?
  order           Int          @default(0)
  sectionId       String?
  type            QuestionType @default(TEXT)
  answerIsRegex   Boolean      @default(false)
  hints           Hint[]
  scenario        Scenario     @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  section         Section?     @relation(fields: [sectionId], references: [id])
  userAnswers     UserAnswer[]
  competencies    Competency[] @relation("CompetencyToQuestion")

  @@map("question")
}

model Hint {
  id         String     @id @default(cuid())
  text       String
  order      Int        @default(0)
  questionId String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userHints  UserHint[]

  @@map("hint")
}

model UserHint {
  id        String   @id @default(cuid())
  userId    String
  hintId    String
  createdAt DateTime @default(now())
  hint      Hint     @relation(fields: [hintId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hintId])
  @@map("user_hint")
}

model UserAnswer {
  id         String   @id @default(cuid())
  answer     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("user_answer")
}

model Competency {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  questions Question[] @relation("CompetencyToQuestion")

  @@map("competency")
}

enum Role {
  STUDENT
  FACULTY
  ADMIN
}

enum QuestionType {
  TEXT
  LONG_TEXT
  MULTIPLE_CHOICE
  TRUE_FALSE
  NUMERIC
  ORDERING
  INFORMATIONAL
}
